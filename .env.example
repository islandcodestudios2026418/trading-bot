# Trading Bot v7.6 Configuration

# === Binance MM (paper) ===
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
MAX_POS_USD=100
DAILY_LOSS_LIMIT=50
CAPITAL=2000
ENTRY_FEE_BPS=5          # paper taker entry fee (bps)
EXIT_FEE_BPS=1           # paper maker exit fee (bps)
STATS_FILE=stats.json    # persistence file

# === OKX API (real trading) ===
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=
OKX_SIMULATED=1          # 1=demo, 0=real
OKX_BASE_URL=https://www.okx.com
OKX_MIN_SPREAD=25        # min spread bps to market-make
OKX_MAX_PAIRS=3          # top N widest-spread pairs
OKX_REQUOTE_BPS=5        # requote if mid moves this much
OKX_SCAN_MIN=10          # rescan pairs interval
OKX_EDGE_BPS=3           # tighten quotes by this much

# === Funding Rate Arb ===
FUNDING_SCAN_MIN=30      # scan interval minutes
FUNDING_THRESHOLD=0.05   # entry: |rate| > this % per 8h
FUNDING_EXIT=0.02        # exit when rate drops below
FUNDING_SIZE_USD=50      # per-leg size USD
FUNDING_ARB_ENABLED=0    # set 1 to auto-execute arbs

# === Cross-Exchange Arb (Binance→OKX) ===
CROSS_ARB_PAIRS=BTCUSDT,ETHUSDT
CROSS_ARB_TRIGGER=8      # min divergence bps (adaptive override possible)
CROSS_ARB_SIZE=30        # USD per trade
CROSS_ARB_COOLDOWN=5     # seconds between trades
CROSS_ARB_LIMIT_BPS=12   # use limit below this, market above

# === Polymarket ===
POLY_PRIVATE_KEY=        # Polygon wallet private key
POLY_EXEC_ENABLED=0      # set 1 to enable real execution
POLY_MAX_SIZE=20         # max USD per arb leg
MIN_PROFIT_PCT=0.3       # min arb profit % to trigger
HTTPS_PROXY=             # for geo-blocked regions

# === Telegram Alerts ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Dashboard ===
PORT=8080

# === Tick Data Recorder ===
RECORD_TICKS=0           # set 1 to record tick data for backtesting
TICK_DATA_DIR=tick_data  # output directory
TICK_ROTATE_HOURS=24     # rotate file every N hours
