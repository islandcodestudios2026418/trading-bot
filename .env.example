# Trading Bot Configuration
MODE=paper              # paper | live

# Capital & Risk
CAPITAL=500
MAX_DRAWDOWN_PCT=5
MAX_POSITION_PCT=10
MAX_EXPOSURE_PCT=50

# OKX API (for live trading) — get from okx.com/account/my-api
